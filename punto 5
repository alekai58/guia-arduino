int led = 9;   // Pin PWM del LED

void setup() {
  pinMode(led, OUTPUT);
}

void loop() {

  // Aumenta el brillo
  for(int i = 0; i <= 255; i++) {
    analogWrite(led, i);
    delay(10);
  }

  // Disminuye el brillo
  for(int i = 255; i >= 0; i--) {
    analogWrite(led, i);
    delay(10);
  }

}
