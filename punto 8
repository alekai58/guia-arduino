int potenciometro = A0;
int led = 8;

int lectura = 0;
float voltaje = 0;

void setup() {

  pinMode(led, OUTPUT);

  Serial.begin(9600);

}

void loop() {

  // Lectura analógica
  lectura = analogRead(potenciometro);

  // Conversión a voltaje
  voltaje = lectura * (5.0 / 1023.0);

  // Mostrar datos
  Serial.print("Lectura: ");
  Serial.print(lectura);

  Serial.print("   Voltaje: ");
  Serial.print(voltaje);

  Serial.println(" V");

  // Condición para encender LED
  if(voltaje > 4.0) {

    digitalWrite(led, HIGH);

  } else {

    digitalWrite(led, LOW);

  }

  delay(200);

}
