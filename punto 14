int joystick = A0;
int motor = 9;

int lectura = 0;
int velocidad = 0;

void setup() {

  pinMode(motor, OUTPUT);

  Serial.begin(9600);

}

void loop() {

  // Leer joystick
  lectura = analogRead(joystick);

  // Convertir a PWM
  velocidad = map(lectura, 0, 1023, 0, 255);

  // Aplicar PWM al motor
  analogWrite(motor, velocidad);

  // Mostrar datos
  Serial.print("Joystick: ");
  Serial.print(lectura);

  Serial.print("   PWM: ");
  Serial.println(velocidad);

  delay(100);

}
